# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/agrodirect

# JWT Secret (use a strong random string in production)
JWT_SECRET=your_jwt_secret_key_change_in_production

# JWT Expiration
JWT_EXPIRE=24h

# Server port
PORT=5000

# Data.gov.in API Configuration
# Get your API key from: https://data.gov.in/
DATA_GOV_API_KEY=your_data_gov_api_key_here
DATA_GOV_API_URL=https://api.data.gov.in/resource

# Variety-wise Daily Market Prices Dataset Resource ID
# Dataset: "Variety-wise Daily Market Prices Data of Commodity"
# Verify at: https://data.gov.in/resource/variety-wise-daily-market-prices-data-commodity
VARIETY_PRICE_RESOURCE_ID=35985678-0d79-46b4-9ed6-6f13308a1d24

# Data Retention Policy (days to keep market price data)
DATA_RETENTION_DAYS=90

# Price Fetch Interval (hours between API fetches)
PRICE_FETCH_INTERVAL_HOURS=24

# Stale Data Threshold (hours after which data is considered stale)
STALE_THRESHOLD_HOURS=24
# ============================================
# Geoapify API Configuration (Logistics Tracking)
# ============================================
# Required for route calculation and distance/ETA computation
# Get your API key from: https://myprojects.geoapify.com/
GEOAPIFY_API_KEY=your_geoapify_api_key_here

# Distance threshold (meters) for NEAR_DESTINATION state
NEAR_DESTINATION_THRESHOLD_METERS=500