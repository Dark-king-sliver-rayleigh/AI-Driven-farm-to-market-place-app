# ============================================
# AgroDirect Frontend Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# Backend API URL
VITE_API_URL=http://localhost:5000/api

# ============================================
# Geoapify API Configuration (Logistics Tracking)
# ============================================
# Required for map visualization and route display
# Get your API key from: https://myprojects.geoapify.com/
VITE_GEOAPIFY_API_KEY=your_geoapify_api_key_here
