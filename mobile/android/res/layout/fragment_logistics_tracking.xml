<?xml version="1.0" encoding="utf-8"?>
<!--
  Logistics Tracking Fragment Layout - Android
  
  PURPOSE:
  Layout for real-time delivery tracking screen.
  Contains MapLibre MapView, status overlay, driver info card, and action buttons.
  
  STRUCTURE:
  - Map container (full screen)
  - Status overlay (top)
  - Driver info card (bottom)
  - Action button (driver mode only)
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".tracking.LogisticsTrackingFragment">

    <!-- MapLibre MapView Container -->
    <org.maplibre.android.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Status Overlay (Top) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/statusCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp"
        app:layout_anchor="@id/map"
        app:layout_anchorGravity="top|center">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Status Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Status Indicator -->
                <View
                    android:id="@+id/statusIndicator"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/status_indicator_bg" />

                <!-- Status Text -->
                <TextView
                    android:id="@+id/statusTextView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="Your order is on the way" />

                <!-- Live Indicator -->
                <LinearLayout
                    android:id="@+id/liveIndicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/live_indicator_bg"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/pulse_dot" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Live"
                        android:textColor="@color/green_600"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Distance and ETA Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Distance -->
                <TextView
                    android:id="@+id/distanceTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawablePadding="4dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    tools:text="📏 2.5 km" />

                <View
                    android:layout_width="16dp"
                    android:layout_height="0dp" />

                <!-- ETA -->
                <TextView
                    android:id="@+id/etaTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawablePadding="4dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    tools:text="⏱️ 12 mins" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <!-- Progress Bar -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="80dp"
                    android:layout_height="8dp"
                    android:max="100"
                    android:progress="45"
                    android:progressDrawable="@drawable/tracking_progress_bar" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Driver Info Card (Bottom) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/driverCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp"
        android:visibility="gone"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <!-- Driver Avatar -->
            <FrameLayout
                android:layout_width="56dp"
                android:layout_height="56dp">

                <View
                    android:id="@+id/driverAvatarBg"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/driver_avatar_bg" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="🚚"
                    android:textSize="28sp" />
            </FrameLayout>

            <!-- Driver Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/driverNameTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="Rajesh Kumar" />

                <TextView
                    android:id="@+id/vehicleNumberTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    tools:text="MH 12 AB 1234" />
            </LinearLayout>

            <!-- Call Button -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/callDriverButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Call Driver"
                android:src="@drawable/ic_phone"
                app:backgroundTint="@color/green_100"
                app:fabSize="normal"
                app:tint="@color/green_600" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Action Button (Driver Mode) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/actionButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="88dp"
        android:text="Start Pickup"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:visibility="gone"
        app:backgroundTint="@color/amber_500"
        app:cornerRadius="12dp"
        tools:visibility="visible" />

    <!-- Delivered Overlay -->
    <LinearLayout
        android:id="@+id/deliveredOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/delivered_overlay_bg"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone"
        tools:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✅"
            android:textSize="48sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Delivery Complete!"
            android:textColor="@color/green_700"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/deliveredTimeTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/green_600"
            android:textSize="14sp"
            tools:text="Delivered at 3:45 PM" />
    </LinearLayout>

    <!-- Loading Overlay -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80FFFFFF"
        android:visibility="gone"
        tools:visibility="gone">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:indeterminateTint="@color/green_500" />
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
